  Mn_max     Decimal? @db.Decimal(10, 4)
  P_min      Decimal? @db.Decimal(10, 4)
  P_max      Decimal? @db.Decimal(10, 4)
  S_min      Decimal? @db.Decimal(10, 4)
  S_max      Decimal? @db.Decimal(10, 4)
  Cr_min     Decimal? @db.Decimal(10, 4)
  Cr_max     Decimal? @db.Decimal(10, 4)
  Ni_min     Decimal? @db.Decimal(10, 4)
  Ni_max     Decimal? @db.Decimal(10, 4)
  Mo_min     Decimal? @db.Decimal(10, 4)
  Mo_max     Decimal? @db.Decimal(10, 4)
  Cu_min     Decimal? @db.Decimal(10, 4)
  Cu_max     Decimal? @db.Decimal(10, 4)
  Fe_min     Decimal? @db.Decimal(10, 4)
  Fe_max     Decimal? @db.Decimal(10, 4)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model visitas_stock_bodega {
  id           Int       @id @default(autoincrement())
  id_cliente   Int
  fecha_visita DateTime  @db.Date
  id_granalla  Int
  kg_bodega    Decimal?  @db.Decimal(10, 2)
  notas        String?   @db.Text
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  clientes     clientes  @relation(fields: [id_cliente], references: [id_cliente], map: "vsb_fk_cliente")
  granallas    granallas @relation(fields: [id_granalla], references: [id_granalla], map: "vsb_fk_granalla")

  @@unique([id_cliente, fecha_visita, id_granalla], map: "uq_cliente_fecha_granalla")
  @@index([id_cliente], map: "idx_id_cliente")
  @@index([id_granalla], map: "idx_id_granalla")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model visitas_stock_maquina {
  id                 Int                @id @default(autoincrement())
  id_visita          Int                @unique(map: "uq_id_visita")
  kg_en_maquina      Decimal?           @db.Decimal(8, 2)
  kg_piso            Decimal?           @db.Decimal(8, 2)
  kg_recuperada      Decimal?           @db.Decimal(8, 2)
  created_at         DateTime?          @default(now()) @db.Timestamp(0)
  visitas_encabezado visitas_encabezado @relation(fields: [id_visita], references: [id_visita], onDelete: Cascade, map: "vsm_fk_visita")
}

enum usuarios_rol {
  super_admin
  cliente
}

enum contactos_maquina_rol {
  Champion
  Machine_User      @map("Machine User")
  Stock_Manager     @map("Stock Manager")
  Contacto_In_Plant @map("Contacto In-Plant")
}

enum granallas_granulometria_tipo {
  MIX_IDEAL
  NUEVO_TEORICO
}

enum visitas_granulometria_tipo_muestra {
  MIX
  DESCARTE
  COLECTOR
}

enum visitas_compras_proveedor {
  DOOBLE
  COMPETENCIA
}

enum visitas_encabezado_evaluacion_estado {
  OPTIMA
  BUENAS_CONDICIONES @map("BUENAS CONDICIONES")
  FUNCIONAL
  INOPERABLE
}

enum visitas_encabezado_evaluacion_eficiencia {
  EFICIENTE__PARAMETROS_DENTRO_DE_RANGO   @map("EFICIENTE: PARAMETROS DENTRO DE RANGO")
  INEFICIENTE__PARAMETROS_FUERA_DE_RANGO  @map("INEFICIENTE: PARAMETROS FUERA DE RANGO")
  INEFICIENTE__PARAMETROS_DENTRO_DE_RANGO @map("INEFICIENTE: PARAMETROS DENTRO DE RANGO")
}
